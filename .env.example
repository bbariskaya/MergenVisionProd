# PostgreSQL
POSTGRES_HOST=mergenvision-postgres
POSTGRES_PORT=5432
POSTGRES_DB=mergenvision
POSTGRES_USER=mergenvision
POSTGRES_PASSWORD=changeme

# Qdrant
QDRANT_URL=http://mergenvision-qdrant:6333

# MinIO
MINIO_ENDPOINT=mergenvision-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_USE_SSL=false

# Application
MERGENVISION_ENV=development
CUDA_VISIBLE_DEVICES=0
MODEL_MANIFEST_PATH=artifacts/models/MODEL_MANIFEST.json

# Retention
VIDEO_RETENTION_DAYS=30
ENROLLMENT_RETENTION_DAYS=365

# Worker queue (one of: postgres, redis; default recommended is postgres)
QUEUE_BACKEND=postgres
